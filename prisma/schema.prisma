generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js required models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ───

enum Role {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  IN_STOCK
  PRE_ORDER
  SOLD_OUT
}

enum ProductCategory {
  BOOSTER
  EXTRA
  PREMIUM
  STARTER
}

enum OrderStatus {
  PENDING
  PAYMENT_UPLOADED
  PAYMENT_CONFIRMED
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentProofStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  displayName   String    @default("")
  phone         String    @default("")
  lineId        String    @default("")
  avatarUrl     String    @default("")
  totalSpent    Int       @default(0)
  orderCount    Int       @default(0)
  role          Role      @default(CUSTOMER)
  image         String?
  name          String?
  referralCode  String?   @unique
  referredById  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  referredBy        User?             @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]            @relation("Referrals")
  accounts          Account[]
  sessions          Session[]
  orders            Order[]
  shippingAddresses ShippingAddress[]
  verifiedPayments  PaymentProof[]    @relation("VerifiedBy")

  @@index([referralCode])
  @@index([referredById])
}

model Product {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  code         String          @unique
  description  String          @default("")
  image        String          @default("")
  boxCount     Int             @default(1)
  pricePerBox  Int
  stock        Int             @default(0)
  status       ProductStatus   @default(IN_STOCK)
  releaseDate  String          @default("")
  packsPerBox  Int             @default(24)
  cardsPerPack Int             @default(12)
  category     ProductCategory?
  islandTheme  Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  orderItems OrderItem[]
}

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique
  userId           String
  status           OrderStatus @default(PENDING)
  subtotal         Int
  discountAmount   Int         @default(0)
  discountRank     String      @default("")
  total            Int
  shippingName     String      @default("")
  shippingPhone    String      @default("")
  shippingAddress  String      @default("")
  shippingProvince String      @default("")
  shippingZipcode  String      @default("")
  trackingNumber   String      @default("")
  paymentMethod    String      @default("bank_transfer")
  note             String      @default("")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  items         OrderItem[]
  paymentProofs PaymentProof[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  productId    String
  productName  String
  productCode  String
  productImage String @default("")
  price        Int
  quantity     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model ShippingAddress {
  id        String  @id @default(cuid())
  userId    String
  name      String
  phone     String
  address   String
  province  String
  zipcode   String
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PaymentProof {
  id         String             @id @default(cuid())
  orderId    String
  imageUrl   String
  status     PaymentProofStatus @default(PENDING)
  verifiedBy String?
  uploadedAt DateTime           @default(now())
  verifiedAt DateTime?

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifier User? @relation("VerifiedBy", fields: [verifiedBy], references: [id])
}

// ─── Card Database ───

model CardSet {
  id       String @id // e.g. "OP-01"
  name     String // e.g. "Romance Dawn"
  cards    Card[]
}

model Card {
  id             String  @id // e.g. "OP01-077"
  cardSetId      String  // FK to CardSet
  cardImageId    String  @default("")
  name           String
  setName        String  @default("")
  cardText       String  @default("")
  rarity         String  // C, UC, R, SR, SEC, L, SP, P, TR
  color          String  @default("")
  cardType       String  @default("") // Character, Event, Stage, Leader
  life           String?
  cost           String?
  power          String?
  subTypes       String  @default("")
  counterAmount  Int?
  attribute      String  @default("")
  marketPrice    Float?
  inventoryPrice Float?
  cardImage      String  @default("") // optcgapi URL

  set CardSet @relation(fields: [cardSetId], references: [id])

  @@index([cardSetId])
  @@index([rarity])
  @@index([name])
}
